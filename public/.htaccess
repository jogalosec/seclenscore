<IfModule mod_rewrite.c>
RewriteEngine On
# RewriteRule .* - [R=503,L]  # Uncomment this line to enable maintenance mode
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.php [QSA,L]
RewriteRule .* - [env=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>
<IfModule mod_headers.c>
Header set Access-Control-Allow-Origin "https://11certools.cisocdo.com"
Header set Access-Control-Allow-Methods "GET, POST"
Header set Access-Control-Allow-Headers "Content-Type"
Header set Content-Security-Policy "default-src 'self' https://www.google.com https://www.gstatic.com https://code.highcharts.com https://cloudflare.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://unpkg.com https://stackpath.bootstrapcdn.com https://code.jquery.com; img-src 'self' data: https://code.jquery.com/ui/1.12.1/themes/base/images/ui-icons_555555_256x240.png https://code.jquery.com/ui/1.12.1/themes/base/images/ui-icons_444444_256x240.png; style-src 'self' 'unsafe-inline' https://stackpath.bootstrapcdn.com https://code.jquery.com https://www.gstatic.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://maxcdn.bootstrapcdn.com; style-src-elem 'self' 'unsafe-inline' http://fonts.googleapis.com/css https://stackpath.bootstrapcdn.com https://code.jquery.com https://www.gstatic.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net https://maxcdn.bootstrapcdn.com; script-src 'self' 'unsafe-inline' https://www.google.com https://www.gstatic.com https://code.highcharts.com https://cloudflare.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com https://unpkg.com https://stackpath.bootstrapcdn.com https://code.jquery.com; font-src 'self' https://maxcdn.bootstrapcdn.com https://fonts.gstatic.com"
Header set X-XSS-Protection "1; mode=block"
Header set X-Content-Type-Options nosniff
Header set Referrer-Policy "strict-origin-when-cross-origin"
Header set Permissions-Policy "geolocation=(), microphone=(), camera=(), fullscreen=(self), payment=()"
Header set Strict-Transport-Security "max-age=31536000; includeSubdomains;"
Header set X-Frame-Options DENY
</IfModule>