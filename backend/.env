# =============================================================
# SecLensCore — Backend FastAPI
# Copiar a .env y rellenar con los valores reales
# NUNCA commitear el .env con valores reales
# =============================================================

# ----- Base de datos MySQL -----
DB_HOST=172.21.0.2
DB_PORT=3306
DB_USER=userdb
DB_PASSWORD=passdb
DB_SSL=false
DB_SSL_CA=../../includes/certCaBD.pem

# Nombres de las bases de datos (no cambiar en producción)
DB_NEW=octopus_new
DB_SERV=octopus_serv
DB_KPMS=octopus_kpms
DB_USER_DB=octopus_users
DB_CACHE=octopus_cache
DB_LOGS=octopus_logs

# ----- JWT / SSL -----
# Ruta a la clave privada RSA (relativa al directorio de trabajo del backend)
JWT_PRIVATE_KEY_PATH=../../includes/privatekey.pem
# Passphrase hex de la clave privada (campo "frase" de config.ini [ssl])
JWT_PRIVATE_KEY_PASSPHRASE=53656375726974794c656e734a6f726765527562656e3031
# Clave AES-256 hex (campo "jtikey" de config.ini [ssl])
JWT_AES_KEY=your_hex_aes_key_here
# IV AES hex (campo "jtiiv" de config.ini [ssl])
JWT_AES_IV=your_hex_aes_iv_here
JWT_ALGORITHM=RS256
JWT_ISSUER=https://app.securitylens.es
JWT_AUDIENCE=SecurityLens

# ----- Azure AD / SSO -----
AZURE_TENANT_ID=9744600e-3e04-492e-baa1-25ec245c6f10
AZURE_CLIENT_ID=your_azure_client_id_here
AZURE_CLIENT_SECRET=your_azure_client_secret_here
AZURE_REDIRECT_URI=http://localhost:8000/auth

# ----- Email / SMTP -----
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=noreply@seclenscore.com
SMTP_TLS=true

# ----- CORS -----
# Lista separada por comas
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8080,https://11certools.cisocdo.com

# ----- Entorno -----
# "development" muestra /docs y /redoc; "production" los oculta
APP_ENV=development
APP_VERSION=2.0.0
