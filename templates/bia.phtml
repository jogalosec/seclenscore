                    $db = new Activos(DB_SERV);
                    if (isset($id['id'])) {
                        $bia = $db->getBia($id['id']);
                    } else {
                        $bia = null;
                    }
                    if (isset($bia[0])) {
                        $biaguardado = true;
                        $bia = json_decode($bia[0]['meta_value'], true);
                    } else {
                        $biaguardado = false;
                    }
                    $db = new DbOperations();
                    $BIA = $db->getPreguntasBIA();
                    $count = 0;
                    foreach ($BIA as $item) {
                        $opcion = "";
                        $opciones = json_decode($item['respuestas']);
                        $countop = 0;
                        foreach ($opciones as $op) {
                            $selected = '';
                            if ($op == "Muy Bajo") {
                                $countop = 0;
                            }
                            if ($biaguardado && isset($bia[$item['id']]) && $countop == intval($bia[$item['id']])) {
                                $selected = 'selected';
                            }
                            $opcion = $opcion . '<option value="' . $countop . '" ' . $selected . '>' . $op . '</option>';
                            $countop++;
                        }
                        $id = $item['id'];
                        $numPregunta += 1;
                        echo '<div class="tarjeta row"><div class="col-10">' . $numPregunta . '-  ' . $item['duda'] . '</div><div class="col-2"><select class="form-select-custom" name="' . $id . '">' . $opcion . '</select></div></div>';
                        $count++;
                    }
